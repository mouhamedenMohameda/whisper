OPENAI_API_KEY=your_key_here
# Groq : génération de cours (/api/generate), collage pipeline, et analyse optionnelle (/api/transcript-insight).
GROQ_API_KEY=your_key_here
# Retries sur rate limit (429 / TPM) pour /generate et analyse — délais exponentiels entre les essais.
# GROQ_HTTP_MAX_RETRIES=5
# GROQ_HTTP_RETRY_BASE_SEC=2.5
# Optionnel : URL d’une passerelle compatible OpenAI (LiteLLM, vLLM, etc.) au lieu de l’API Groq publique.
# GROQ_BASE_URL=https://votre-proxy.example/v1
# Si true : n’appelle jamais l’étape collage (JSON ASR) — le cours est généré directement depuis le transcript brut.
# GENERATE_SKIP_COLLAGE=false
# Transcription Whisper **locale** : les segments n’ont souvent pas les métriques complètes → score ASR < seuil.
# Le backend saute alors automatiquement le collage et utilise le transcript pour le cours. Tu peux aussi baisser :
# GENERATE_MIN_WHISPER_RELIABILITY_SCORE=90
# Si true : lance aussi sujet+synthèse Groq pendant chaque /transcribe (sinon : uniquement sur demande via /api/transcript-insight dans l’UI).
# TRANSCRIBE_ENABLE_GROQ_INSIGHT=false
#
# --- Recommandé compte Groq payant (simple : copier / décommenter) ---
# Gros volume sur modèle rapide / bon marché ; une seule étape « premium » pour le cours.
# GROQ_GENERATE_MODEL=llama-3.3-70b-versatile
# GROQ_GENERATE_MAX_TOKENS=8192
# GROQ_COLLAGE_MODEL=llama-3.1-8b-instant
# GROQ_COLLAGE_MAX_TOKENS=16384
# GROQ_MAP_NOTES_MODEL=llama-3.1-8b-instant
# GROQ_MAP_MAX_TOKENS=4096
# GROQ_INSIGHT_MODEL=llama-3.1-8b-instant
# Facturation MRU (un seul tarif pour tout Groq dans le code) : mets le tarif du modèle le plus cher
# que tu utilises (ex. 70B) pour ne pas sous-facturer la génération du cours.
# GROQ_INPUT_USD_PER_MTOK=0.59
# GROQ_OUTPUT_USD_PER_MTOK=0.79
#
# Variante tout-8B (moins cher, qualité moindre sur la leçon) : même modèle pour GROQ_GENERATE / COLLAGE / MAP / INSIGHT
# et tarifs 0.05 / 0.08. Puis :
# GENERATE_MAP_CHUNK_CHARS=12000
# GENERATE_SINGLE_LESSON_MAX_SOURCE_CHARS=45000
# GENERATE_REDUCE_MAX_NOTES_CHARS=95000
# Taille max du JSON INPUT_JSON (passages + scores) envoyé au collage Groq
# GENERATE_ASR_JSON_MAX_CHARS=280000
# Seuil score Whisper (0–100) sur les blocs texte de transcript_mixed_view ; défaut 90
# GENERATE_MIN_WHISPER_RELIABILITY_SCORE=90
# Authentification (JWT + SQLite par défaut)
JWT_SECRET=min-16-chars-random-change-in-production-xx
AUTH_REQUIRED=true
# Optionnel ; par défaut: sqlite:///.../backend/data/lecturai.db
# DATABASE_URL=sqlite:///./data/lecturai.db

# Compte administrateur unique : cet e-mail reçoit is_admin=true au démarrage (voir /api/admin/credit-topups*, JWT Bearer)
ADMIN_EMAIL=admin@example.com

# Rate-limit global par client (IP ou user JWT) pour toutes les routes. Format slowapi : "N/unit".
# Limites fines (/auth/login, /auth/register, /generate, etc.) sont posées dans le code.
RATE_LIMIT_DEFAULT=120/minute

# Liste optionnelle d'e-mails (séparés par virgule) d'utilisateurs perdus lors d'une perte de base SQLite.
# Si l'un de ces e-mails tente de se connecter sans compte en base, un message explicite l'invite à se réinscrire.
# Exemple : LEGACY_REREGISTER_EMAILS=alice@example.com,bob@example.com
LEGACY_REREGISTER_EMAILS=

# Portefeuille (MRU) — users.credit_balance : entier d’UNITÉS (pas de fraction en base).
# Une unité représente 1/MRU_WALLET_MICRO de MRU ; sans changer le schéma ni monter MRU_WALLET_MICRO,
# la quantification impose un arrondi : côté code, demi au plus proche (ni ceil systématique ni floor).
# Pour réduire l’erreur sur des montants minuscules, augmenter MRU_WALLET_MICRO (ex. 100000 au lieu de 10000).
# Débit automatique après chaque action : MRU facturés ≈ coût USD APIs × MRU_PER_USD × marge (puis conversion unités).
# Vide ou absent → aucun bonus à l’inscription (0) ; définir un entier >0 pour offrir des unités portefeuille à l’inscription.
# CREDITS_REGISTRATION_BONUS=
CREDITS_REGISTRATION_VALIDITY_DAYS=365
CREDITS_TOPUP_APPROVE_EXTEND_DAYS=90
# Anciens débits en « unités » — laissés à 0 lorsque vous utilisez le système MRU intégré.
CREDITS_DEBIT_TRANSCRIBE=0
CREDITS_DEBIT_GENERATE=0
CREDITS_DEBIT_EXPORT=0
# Coût forfait fournisseur (USD) par export PDF/DOCX — converti comme les autres cotations.
EXPORT_JOB_PROVIDER_USD=0.0005
# Optionnel ; défaut 10000 (= 4 décimales MRU par unité entière). Plus élevé = plus fin, moins d’erreur de quantification.
# MRU_WALLET_MICRO=10000
# MRU_WALLET_MICRO=100000

# Frontend CORS — domaines autorisés à appeler l'API depuis un navigateur.
# PRODUCTION : lister explicitement (jamais "*" avec AUTH_REQUIRED=true, sinon CSRF possible).
# Exemple : ALLOWED_ORIGINS=https://lecturai.vercel.app,https://www.lecturai.com
# DEV LOCAL : laisser "*" est OK uniquement si tu ne te connectes pas avec un vrai compte.
# Preview deploys Vercel (URL dynamique par PR) → utilise un regex :
# ALLOWED_ORIGIN_REGEX=^https://lecturai-[a-z0-9-]+\.vercel\.app$
ALLOWED_ORIGINS=http://localhost:5173

# Billable estimates shown to users (optional overrides)
# Défauts côté code : MRU_PER_USD=40, CUSTOMER_MARGIN_MULTIPLIER=1.28 (surchargeable).
MRU_PER_USD=40
CUSTOMER_MARGIN_MULTIPLIER=1.28
# Tarif OpenAI utilisé pour estimer USD des appels GPT sur /transcribe (chat polish + vue langues).
# À caler sur le tarif officiel au million de tokens du modèle réellement appelé.
# OPENAI_TRANSCRIBE_CHAT_INPUT_USD_PER_MTOK=0.15
# OPENAI_TRANSCRIBE_CHAT_OUTPUT_USD_PER_MTOK=0.60
# Marge/transcription agrégée (Whisper_audio + GPT transcribe ) : défaut = CUSTOMER_MARGIN_MULTIPLIER ; mettre « 3 » pour ×3 strict sur tout le coût fournisseur.
# TRANSCRIBE_AI_RETAIL_MULTIPLIER=
OPENAI_WHISPER_USD_PER_MINUTE=0.006

# --- Whisper local (mode expérimental, dossier backend/experimental/) ---
# Une fois à true : pip install -r requirements.txt puis pip install -r requirements-whisper-local.txt (+ ffmpeg dans le PATH).
# Si « Connection reset by peer » sur PyPI : réessaie, ou pip install avec --retries 10 --timeout 120
#TRANSCRIBE_LOCAL_WHISPER_ENABLED=true
# Petits VPS : tiny / base ; qualité meilleure avec small ou medium selon RAM.
#TRANSCRIBE_LOCAL_WHISPER_MODEL=small
#TRANSCRIBE_LOCAL_WHISPER_DEVICE=cuda   # sinon laisser vide pour auto (cuda si disponible sinon cpu)
#TRANSCRIBE_LOCAL_WHISPER_FP16=false
#TRANSCRIBE_LOCAL_WHISPER_DOWNLOAD_ROOT=/chemin/cache/weights
# Défaut : températures multiples Whisper sur échec (plus robuste que temperature=0 seul).
# Définir ex. TRANSCRIBE_LOCAL_WHISPER_TEMPERATURE=0 pour un décodage strictement greedy.
#TRANSCRIBE_LOCAL_WHISPER_TEMPERATURE=
# Jobs POST /api/transcribe-jobs : au plus N transcriptions « lourdes » en parallèle **par process uvicorn** (défaut 2).
# Avec plusieurs workers (uvicorn --workers M), capacité globale ~ M × N. Mettre 0 pour désactiver la limite.
#TRANSCRIBE_JOB_MAX_CONCURRENT=2
# Jobs authentifiés : réserve un plafond MRU au début du traitement puis solde au réel à la fin ; en échec / abandon la réserve est recréditée (upload interrompu avant 202 = aucune réserve).
#TRANSCRIBE_JOB_WALLET_HOLD=true
# Surcôte USD fournisseur (Groq / vues langues) incluse dans la réserve — évite « solde insuffisant » à la clôture si le coût réel dépasse l’estimation Whisper seule.
#TRANSCRIBE_JOB_HOLD_EXTRA_PROVIDER_USD=0.04
#TRANSCRIBE_JOB_HOLD_SAFETY_MULTIPLIER=1.12
# Défaut : condition_on_previous_text=false (réduit hallucinations « la la la… » sur longs fichiers / silence).
# Mettre TRANSCRIBE_LOCAL_WHISPER_CONDITION_ON_PREVIOUS_TEXT=true pour coller mieux fenêtre-par-fenêtre (plus risque de boucles).
#TRANSCRIBE_LOCAL_WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
# Seuils Whisper (optionnels ; laissés au défaut whisper si absent) — serrent le décodage contre répétitions / non-parole :
#TRANSCRIBE_LOCAL_WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
#TRANSCRIBE_LOCAL_WHISPER_LOGPROB_THRESHOLD=-1.0
#TRANSCRIBE_LOCAL_WHISPER_NO_SPEECH_THRESHOLD=0.65
# Whisper local uniquement — rembourrage minimal si clip très court (secondes ; ne tronque jamais ; défaut 1.0).
#TRANSCRIBE_LOCAL_WHISPER_MIN_PAD_SEC=1.0
# Fichiers découpés en plusieurs segments : si le dernier fait moins que N secondes, il est fusionné avec l’avant-dernier (évite erreurs reshape sur CPU).
#TRANSCRIBE_LOCAL_MIN_CHUNK_SECONDS=3.0
#WHISPER_PROGRESS_RT_FACTOR_LOCAL=12
# Transcription : taille max acceptée par l’application (reverse proxy doit accepter ce corps upload).
TRANSCRIBE_MAX_MB=100
TRANSCRIBE_MAX_DURATION_SECONDS=7200
# Taille réelle envoyée à OpenAI whisper-1 (une requête) — erreur très fréquente si dépassée alors que TRANSCRIBE_MAX_MB est plus grand.
OPENAI_WHISPER_MAX_UPLOAD_MB=25
# Pendant la préparation FFmpeg (fichiers longs), /transcribe-stream envoie un statut NDJSON au moins toutes les N secondes (évite timeout proxy).
# TRANSCRIBE_STREAM_PREP_HEARTBEAT_SEC=12
# Par défaut, aucun « prompt de style » Whisper (évite boucles du type même phrase 1 h — sans rien saisir comme matière).
# Texte d’orientation « cours oral » fr/ar uniquement si :
# TRANSCRIBE_WHISPER_STYLE_PROMPT=true
# Par défaut, le champ « matière » n’est pas injecté dans le prompt Whisper.
# TRANSCRIBE_WHISPER_SUBJECT_IN_PROMPT=false
# TRANSCRIBE_WHISPER_SUBJECT_MAX_CHARS=42
# Pré-traitement FFmpeg avant Whisper (mono 16 kHz, passe-haut + dynaudnorm, MP3) — désactivé si ffmpeg absent dans le PATH.
# TRANSCRIBE_ENABLE_AUDIO_PREPROCESS=true
# Binaire FFmpeg (défaut : « ffmpeg » résolu depuis le PATH ; ex. /usr/bin/ffmpeg).
# FFMPEG_BINARY=
# Chaîne filtres FFmpeg complète après -af ; défaut : highpass + dynaudnorm.
# TRANSCRIBE_AUDIO_FILTER=highpass=f=90,dynaudnorm=f=210:g=27
# Bitrate lame ; vide = choix auto selon la durée (~40k→20k mono pour rester sous OPENAI_WHISPER_MAX_UPLOAD_MB).
# TRANSCRIBE_MP3_BITRATE=
# TRANSCRIBE_FFMPEG_TIMEOUT_SEC=840
# Détection langdetect + traduction GPT (gpt-4o-mini) pour une 2ᵉ vue : passages hors langue du cours vers fr/ar (sans débit MRU séparé).
# TRANSCRIBE_ENABLE_MIXED_LANG_VIEW=true
# TRANSCRIBE_MIXED_LANG_MODEL=gpt-4o-mini
# Longueur min. d’un segment pour tenter une détection (réduit les faux positifs).
# TRANSCRIBE_MIXED_LANG_DETECT_MIN_CHARS=18
# Probabilité minimale langdetect avant de qualifier un segment « langue étrangère ».
# TRANSCRIBE_MIXED_LANG_CONFIDENCE=0.88
# Seuil pour les très courts snippets anglais imbriqués (plus bas pour mieux détecter “structure of progress”, etc.).
# TRANSCRIBE_MIXED_LANG_CONFIDENCE_SHORT=0.78
# Nombre max de segments par appel au modèle de traduction.
# TRANSCRIBE_MIXED_LANG_BATCH_MAX=32

# Polish sémantique post‑Whisper (GPT) : réduit erreurs phonétiques (ex. encore / liaison « un corps… » aberrante si contexte absurd) FR,
# harmonise dialectes arabes oral → MSA cours. Active consommation GPT en plus du modèle Whisper.
# TRANSCRIBE_ENABLE_SEMANTIC_POLISH=false
# TRANSCRIBE_SEMANTIC_POLISH_MODEL=gpt-4o-mini
# TRANSCRIBE_SEMANTIC_POLISH_BATCH_SEGMENTS=24

# Tarifs Groq (USD / million de tokens) pour MRU — voir bloc « Recommandé compte Groq payant » ci-dessus.
# GROQ_INPUT_USD_PER_MTOK=0.59
# GROQ_OUTPUT_USD_PER_MTOK=0.79

# ───────────────────────────────────────────────────────────────────────────────
# Bot WhatsApp (Meta Cloud API) — désactivé par défaut tant que les 4 variables critiques
# (PHONE_NUMBER_ID, ACCESS_TOKEN, VERIFY_TOKEN, APP_SECRET) ne sont pas remplies sur le VPS.
# Setup côté Meta : https://developers.facebook.com → app → WhatsApp → API Setup.
# ───────────────────────────────────────────────────────────────────────────────
# WHATSAPP_PHONE_NUMBER_ID=1126469573882393
# WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxx... (en prod : System User Token permanent, pas le temporaire 24h)
# WHATSAPP_VERIFY_TOKEN=chaine-arbitraire-min-32-chars-que-tu-copies-aussi-côté-Meta-webhook
# WHATSAPP_APP_SECRET=trouvable-dans-App-Settings-Basic-developers.facebook.com (obligatoire pour HMAC)
# WHATSAPP_GRAPH_API_VERSION=v23.0
# WHATSAPP_DEFAULT_LANG=fr           # fr | ar — langue par défaut des réponses bot
# WHATSAPP_DRY_RUN=false             # true → toutes les requêtes sortantes sont log-only (test local)
# WHATSAPP_PROCESS_TIMEOUT_SEC=900   # Timeout global d'un audio (téléchargement + transcription + génération)
# WHATSAPP_MAX_MEDIA_BYTES=62914560  # 60 MB — taille max d'un audio reçu de Meta
# WHATSAPP_SIMULATE_TOKEN=           # vide en prod ; si défini → route /api/whatsapp/_simulate accessible
